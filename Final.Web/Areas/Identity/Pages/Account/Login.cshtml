@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-wrap anim-in">
    <div class="auth-panel">
        <div>
            <h2>Welcome back</h2>
            <p>Sign in to manage your bookings, wishlist and properties.</p>
        </div>
        <ul class="auth-points">
            <li><i class="bi bi-shield-check"></i> No double-booking, ever</li>
            <li><i class="bi bi-heart"></i> Your wishlist, saved</li>
            <li><i class="bi bi-lightning-charge"></i> Instant confirmation</li>
        </ul>
    </div>
    <div class="auth-form">
        <h1>Log in</h1>
        <p class="auth-sub">New to StayFinder? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a></p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Your password" />
                <span asp-validation-for="Input.Password"></span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
                </div>
                <a id="forgot-password" asp-page="./ForgotPassword" class="small">Forgot password?</a>
            </div>
            <button id="login-submit" type="submit" class="btn btn-primary w-100"><i class="bi bi-box-arrow-in-right"></i> Log in</button>
            <p class="text-center small mt-3 mb-0">
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
            </p>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <hr class="my-4" />
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div class="d-grid gap-2">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                            @provider.DisplayName
                        </button>
                    }
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
