@model IEnumerable<Bookings>
@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-1">
    <h1 class="page-title mb-0">Bookings</h1>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> New booking</a>
</div>
<p class="page-subtitle"><i class="bi bi-clock"></i> Standard schedule: check-in 14:00 — check-out 12:00.</p>

@if (!Model.Any())
{
    <div class="card p-5 text-center text-muted">
        <div style="font-size:2.5rem;"><i class="bi bi-calendar-x"></i></div>
        <p class="mb-0">No bookings yet.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="table table-hover">
            <thead>
                <tr><th>Room</th><th>Client</th><th>Check-in</th><th>Check-out</th><th>Total</th><th>Status</th><th class="text-end"></th></tr>
            </thead>
            <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>Room @b.Room?.Number</td>
                    <td>@b.Client?.Name</td>
                    <td>@b.StartDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@b.EndDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="price-tag">@(b.Payment?.Total.ToString("C") ?? "-")</td>
                    <td><span class="badge-soft">@b.Status</span></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="d-inline" onsubmit="return confirm('Cancel this booking?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
