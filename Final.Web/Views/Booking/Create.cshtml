@model Bookings
@{
    ViewData["Title"] = "New booking";
    var rooms = ViewBag.Rooms as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var clients = ViewBag.Clients as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<h1 class="page-title mb-1"><i class="bi bi-calendar-plus"></i> New booking</h1>
<p class="page-subtitle"><i class="bi bi-clock"></i> Check-in is fixed at 14:00 and check-out at 12:00.</p>

<div class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="RoomId" class="form-label">Room</label>
            <select asp-for="RoomId" asp-items="rooms" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="ClientId" class="form-label">Client</label>
            <select asp-for="ClientId" asp-items="clients" class="form-select"></select>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="StartDate" class="form-label">Check-in date</label>
                <input asp-for="StartDate" class="form-control" type="date" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="EndDate" class="form-label">Check-out date</label>
                <input asp-for="EndDate" class="form-control" type="date" />
            </div>
        </div>
        <button type="submit" class="btn btn-success">Confirm booking</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
