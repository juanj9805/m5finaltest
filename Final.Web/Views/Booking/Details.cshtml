@model Bookings
@{
    ViewData["Title"] = "Booking details";
}

<a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back</a>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card form-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="page-title mb-0">Booking #@Model.Id</h1>
                <span class="badge-soft">@Model.Status</span>
            </div>
            <dl class="row mb-0">
                <dt class="col-sm-4">Room</dt><dd class="col-sm-8">Room @Model.Room?.Number</dd>
                <dt class="col-sm-4">Client</dt><dd class="col-sm-8">@Model.Client?.Name</dd>
                <dt class="col-sm-4">Check-in</dt><dd class="col-sm-8">@Model.StartDate.ToString("yyyy-MM-dd HH:mm")</dd>
                <dt class="col-sm-4">Check-out</dt><dd class="col-sm-8">@Model.EndDate.ToString("yyyy-MM-dd HH:mm")</dd>
            </dl>
        </div>
    </div>

    @if (Model.Payment is not null)
    {
        <div class="col-md-5">
            <div class="card form-card">
                <h4 class="mb-3"><i class="bi bi-receipt"></i> Payment</h4>
                <div class="d-flex justify-content-between"><span class="text-muted">Subtotal</span><span>@Model.Payment.SubTotal.ToString("C")</span></div>
                <div class="d-flex justify-content-between"><span class="text-muted">Tax (19%)</span><span>@Model.Payment.Tax.ToString("C")</span></div>
                <hr />
                <div class="d-flex justify-content-between fs-5"><strong>Total</strong><strong class="price-tag">@Model.Payment.Total.ToString("C")</strong></div>
            </div>
        </div>
    }
</div>
