@model Bookings
@{
    ViewData["Title"] = "Booking details";

    var statusChip = (Model.Status ?? "").ToLowerInvariant() switch
    {
        "" => "chip-neutral",
        var s when s.Contains("confirm") || s.Contains("paid") || s.Contains("active") => "chip-ok",
        var s when s.Contains("cancel") || s.Contains("reject") => "chip-danger",
        var s when s.Contains("pend") || s.Contains("hold") => "chip-warn",
        _ => "chip-pine"
    };
}

<nav aria-label="breadcrumb" class="anim-in">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Bookings</a></li>
        <li class="breadcrumb-item active" aria-current="page">Booking #@Model.Id</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-7">
        <div class="detail-card anim-in">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                <h1 class="page-title mb-0">Booking #@Model.Id</h1>
                <span class="chip @statusChip">@Model.Status</span>
            </div>
            <dl class="detail-grid">
                <div>
                    <dt>Room</dt>
                    <dd><i class="bi bi-door-open"></i> Room @Model.Room?.Number</dd>
                </div>
                <div>
                    <dt>Client</dt>
                    <dd><i class="bi bi-person"></i> @Model.Client?.Name</dd>
                </div>
                <div>
                    <dt>Check-in</dt>
                    <dd>@Model.StartDate.ToString("MMM d, yyyy · HH:mm")</dd>
                </div>
                <div>
                    <dt>Check-out</dt>
                    <dd>@Model.EndDate.ToString("MMM d, yyyy · HH:mm")</dd>
                </div>
            </dl>
        </div>
    </div>

    @if (Model.Payment is not null)
    {
        <div class="col-md-5">
            <div class="detail-card anim-in d-1">
                <h4 class="mb-3"><i class="bi bi-receipt"></i> Payment</h4>
                <div class="d-flex justify-content-between py-1"><span class="text-muted">Subtotal</span><span>@Model.Payment.SubTotal.ToString("C")</span></div>
                <div class="d-flex justify-content-between py-1"><span class="text-muted">Tax (19%)</span><span>@Model.Payment.Tax.ToString("C")</span></div>
                <hr />
                <div class="d-flex justify-content-between fs-5"><strong>Total</strong><strong class="price-tag">@Model.Payment.Total.ToString("C")</strong></div>
            </div>
        </div>
    }
</div>
