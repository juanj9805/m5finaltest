@model IEnumerable<Hotel>
@{
    ViewData["Title"] = "Properties";
    var city = ViewBag.City as string;
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title">Properties</h1>
        <p class="page-subtitle mb-0">Browse available properties. No account needed to look around.</p>
    </div>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> New property</a>
    }
</div>

<form method="get" class="row g-2 my-3">
    <div class="col-sm-5 col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-geo-alt"></i></span>
            <input type="text" name="city" value="@city" class="form-control" placeholder="Filter by city" />
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card p-5 text-center text-muted">
        <div style="font-size:2.5rem;"><i class="bi bi-search"></i></div>
        <p class="mb-0">No properties found@(string.IsNullOrWhiteSpace(city) ? "" : $" in \"{city}\"").</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var h in Model)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card property-card h-100">
                    <div class="card-cover"><i class="bi bi-building"></i></div>
                    <div class="card-body">
                        <h5 class="card-title mb-1">@h.Name</h5>
                        <p class="text-muted mb-2"><i class="bi bi-geo-alt"></i> @h.City</p>
                        <p class="small text-muted mb-3">@h.Address</p>
                        <span class="badge-soft"><i class="bi bi-door-open"></i> @h.Rooms.Count rooms</span>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2 flex-wrap pb-3">
                        <a asp-action="Details" asp-route-id="@h.Id" class="btn btn-sm btn-primary">View</a>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-inline">
                                <input type="hidden" name="hotelId" value="@h.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-heart"></i> Save</button>
                            </form>
                            <a asp-action="Edit" asp-route-id="@h.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
