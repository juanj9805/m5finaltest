@model Client
@{
    ViewData["Title"] = Model.Name;
}

<a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back</a>

<div class="card form-card">
    <h1 class="page-title"><i class="bi bi-person-circle"></i> @Model.Name</h1>
    <p class="text-muted mb-0"><i class="bi bi-envelope"></i> @Model.Email</p>
</div>
