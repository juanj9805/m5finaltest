@model Client
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="anim-in">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Clients</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="detail-card anim-in" style="max-width: 560px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <span class="avatar d-inline-flex align-items-center justify-content-center rounded-circle"
              style="width:56px;height:56px;background:var(--pine);color:#fff;font-weight:700;font-size:1.4rem;text-transform:uppercase;">
            @Model.Name[0]
        </span>
        <div>
            <h1 class="page-title mb-0">@Model.Name</h1>
            <p class="page-subtitle mb-0">Client profile</p>
        </div>
    </div>

    <dl class="detail-grid mb-4">
        <div>
            <dt>Email</dt>
            <dd><i class="bi bi-envelope"></i> @Model.Email</dd>
        </div>
    </dl>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">All clients</a>
    </div>
</div>
