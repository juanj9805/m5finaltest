@model Client
@{
    ViewData["Title"] = "New client";
}

<nav aria-label="breadcrumb" class="anim-in">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Clients</a></li>
        <li class="breadcrumb-item active" aria-current="page">New client</li>
    </ol>
</nav>

<div class="form-card anim-in">
    <div class="form-card-head">
        <h1><i class="bi bi-person-plus"></i> New client</h1>
        <p>Register a client to create bookings on their behalf.</p>
    </div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly"></div>
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Full name" />
            <span asp-validation-for="Name"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" type="email" placeholder="name@example.com" />
            <span asp-validation-for="Email"></span>
        </div>
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save client</button>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
