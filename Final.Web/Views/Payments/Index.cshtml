@model IEnumerable<Payments>
@{
    ViewData["Title"] = "Payments";
}

<h1 class="page-title mb-3">Payments</h1>

@if (!Model.Any())
{
    <div class="card p-5 text-center text-muted">
        <div style="font-size:2.5rem;"><i class="bi bi-receipt"></i></div>
        <p class="mb-0">No payments recorded yet.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="table table-hover">
            <thead>
                <tr><th>#</th><th>Booking</th><th>Subtotal</th><th>Tax</th><th>Total</th><th>Date</th></tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>#@p.BookingId</td>
                    <td>@p.SubTotal.ToString("C")</td>
                    <td>@p.Tax.ToString("C")</td>
                    <td class="price-tag">@p.Total.ToString("C")</td>
                    <td class="text-muted">@p.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
