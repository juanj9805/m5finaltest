@model Payments
@{
    ViewData["Title"] = "Payment details";
}

<nav aria-label="breadcrumb" class="anim-in">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Payments</a></li>
        <li class="breadcrumb-item active" aria-current="page">Payment #@Model.Id</li>
    </ol>
</nav>

<div class="detail-card anim-in" style="max-width: 480px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <span class="icon-tile mb-0"><i class="bi bi-receipt"></i></span>
        <div>
            <h1 class="page-title mb-0">Payment #@Model.Id</h1>
            <p class="page-subtitle mb-0">@Model.CreatedAt.ToString("MMMM d, yyyy") · Booking <a asp-controller="Booking" asp-action="Details" asp-route-id="@Model.BookingId">#@Model.BookingId</a></p>
        </div>
    </div>

    <div class="d-flex justify-content-between py-1"><span class="text-muted">Subtotal</span><span>@Model.SubTotal.ToString("C")</span></div>
    <div class="d-flex justify-content-between py-1"><span class="text-muted">Tax</span><span>@Model.Tax.ToString("C")</span></div>
    <hr />
    <div class="d-flex justify-content-between fs-5"><strong>Total</strong><strong class="price-tag">@Model.Total.ToString("C")</strong></div>
</div>
