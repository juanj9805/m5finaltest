@model Payments
@{
    ViewData["Title"] = "Payment details";
}

<a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back</a>

<div class="card form-card">
    <h1 class="page-title mb-3"><i class="bi bi-receipt"></i> Payment #@Model.Id</h1>
    <div class="d-flex justify-content-between"><span class="text-muted">Booking</span><span>#@Model.BookingId</span></div>
    <div class="d-flex justify-content-between"><span class="text-muted">Subtotal</span><span>@Model.SubTotal.ToString("C")</span></div>
    <div class="d-flex justify-content-between"><span class="text-muted">Tax</span><span>@Model.Tax.ToString("C")</span></div>
    <hr />
    <div class="d-flex justify-content-between fs-5"><strong>Total</strong><strong class="price-tag">@Model.Total.ToString("C")</strong></div>
</div>
