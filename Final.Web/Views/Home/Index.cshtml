@{
    ViewData["Title"] = "Home";
}

<section class="hero text-center">
    <h1 class="display-4">Find your next stay</h1>
    <p class="lead mt-3 mb-4">Browse properties freely — sign in only when you want to book or save a favourite.</p>
    <a asp-controller="Hotel" asp-action="Index" class="btn btn-light btn-lg px-4">
        <i class="bi bi-search"></i> Browse properties
    </a>
</section>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div class="mb-2" style="font-size:2rem;color:var(--brand);"><i class="bi bi-shield-check"></i></div>
            <h5>Strict availability</h5>
            <p class="text-muted mb-0">No double-booking: a room can't be reserved for overlapping dates.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div class="mb-2" style="font-size:2rem;color:var(--brand);"><i class="bi bi-clock-history"></i></div>
            <h5>Standard schedule</h5>
            <p class="text-muted mb-0">Every confirmed booking is check-in 14:00, check-out 12:00.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div class="mb-2" style="font-size:2rem;color:var(--brand);"><i class="bi bi-heart-fill"></i></div>
            <h5>Save favourites</h5>
            <p class="text-muted mb-0">Build a wishlist and pick up where you left off next time.</p>
        </div>
    </div>
</div>
