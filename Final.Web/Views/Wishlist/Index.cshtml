@model IEnumerable<Hotel>
@{
    ViewData["Title"] = "My wishlist";
}

<h1 class="page-title mb-3"><i class="bi bi-heart-fill text-danger"></i> My wishlist</h1>

@if (!Model.Any())
{
    <div class="card p-5 text-center text-muted">
        <div style="font-size:2.5rem;"><i class="bi bi-heart"></i></div>
        <p class="mb-0">You haven't saved any properties yet. Browse the <a asp-controller="Hotel" asp-action="Index">catalog</a> and tap <i class="bi bi-heart"></i> Save.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var h in Model)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card property-card h-100">
                    <div class="card-cover"><i class="bi bi-building"></i></div>
                    <div class="card-body">
                        <h5 class="card-title mb-1">@h.Name</h5>
                        <p class="text-muted mb-2"><i class="bi bi-geo-alt"></i> @h.City</p>
                        <p class="small text-muted mb-0">@h.Address</p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2 pb-3">
                        <a asp-controller="Hotel" asp-action="Details" asp-route-id="@h.Id" class="btn btn-sm btn-primary">View</a>
                        <form asp-action="Remove" method="post" class="d-inline">
                            <input type="hidden" name="hotelId" value="@h.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-heart-fill"></i> Remove</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
