@model Room
@{
    ViewData["Title"] = "New room";
    var hotels = ViewBag.Hotels as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<nav aria-label="breadcrumb" class="anim-in">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Rooms</a></li>
        <li class="breadcrumb-item active" aria-current="page">New room</li>
    </ol>
</nav>

<div class="form-card anim-in">
    <div class="form-card-head">
        <h1><i class="bi bi-door-open"></i> New room</h1>
        <p>Add a bookable room to one of your properties.</p>
    </div>
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly"></div>
        <div class="mb-3">
            <label asp-for="HotelId" class="form-label">Property</label>
            <select asp-for="HotelId" asp-items="hotels" class="form-select"></select>
            <span asp-validation-for="HotelId"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Number" class="form-label"></label>
                <input asp-for="Number" class="form-control" />
                <span asp-validation-for="Number"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Capacity" class="form-label"></label>
                <input asp-for="Capacity" class="form-control" type="number" min="1" />
                <span asp-validation-for="Capacity"></span>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="DayBasePrice" class="form-label">Price per night</label>
            <input asp-for="DayBasePrice" class="form-control" type="number" step="0.01" min="0" />
            <div class="form-text">Base rate before taxes.</div>
            <span asp-validation-for="DayBasePrice"></span>
        </div>
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save room</button>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
