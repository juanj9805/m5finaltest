@model Room
@{
    ViewData["Title"] = $"Room {Model.Number}";
}

<nav aria-label="breadcrumb" class="anim-in">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Rooms</a></li>
        <li class="breadcrumb-item active" aria-current="page">Room @Model.Number</li>
    </ol>
</nav>

<div class="detail-card anim-in" style="max-width: 640px;">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="page-title mb-1">Room @Model.Number</h1>
            <p class="page-subtitle"><i class="bi bi-building"></i> @Model.Hotel?.Name</p>
        </div>
        <span class="price-tag fs-4">@Model.DayBasePrice.ToString("C") <small>/ night</small></span>
    </div>

    <dl class="detail-grid mb-4">
        <div>
            <dt>Capacity</dt>
            <dd><i class="bi bi-people"></i> @Model.Capacity guests</dd>
        </div>
        <div>
            <dt>Schedule</dt>
            <dd><i class="bi bi-clock"></i> 14:00 — 12:00</dd>
        </div>
    </dl>

    <a asp-controller="Booking" asp-action="Create" asp-route-roomId="@Model.Id" class="btn btn-primary"><i class="bi bi-calendar-plus"></i> Book this room</a>
</div>
