@model Room
@{
    ViewData["Title"] = $"Room {Model.Number}";
}

<a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back</a>

<div class="card form-card">
    <h1 class="page-title">Room @Model.Number</h1>
    <p class="text-muted mb-3">@Model.Hotel?.Name</p>
    <div class="d-flex gap-4 mb-3">
        <span><i class="bi bi-people"></i> Capacity: <strong>@Model.Capacity</strong></span>
        <span class="price-tag">@Model.DayBasePrice.ToString("C") / night</span>
    </div>
    <a asp-controller="Booking" asp-action="Create" asp-route-roomId="@Model.Id" class="btn btn-primary"><i class="bi bi-calendar-plus"></i> Book this room</a>
</div>
