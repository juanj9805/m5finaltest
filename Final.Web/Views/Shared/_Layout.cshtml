<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="StayFinder — find and book your next stay. Browse properties, compare rooms and reserve in minutes." />
    <meta name="theme-color" content="#faf7f2" />
    <title>@ViewData["Title"] - StayFinder</title>
    <link rel="preload" href="~/fonts/plus-jakarta-sans-v12-latin-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        string NavActive(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light app-nav">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark"><i class="bi bi-buildings-fill"></i></span> StayFinder
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-sm-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Hotel")" asp-area="" asp-controller="Hotel" asp-action="Index"><i class="bi bi-grid"></i> Properties</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Room")" asp-area="" asp-controller="Room" asp-action="Index"><i class="bi bi-door-open"></i> Rooms</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item d-none d-sm-block nav-divider" aria-hidden="true"></li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Booking")" asp-area="" asp-controller="Booking" asp-action="Index"><i class="bi bi-calendar-check"></i> Bookings</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Wishlist")" asp-area="" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart"></i> Wishlist</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Client")" asp-area="" asp-controller="Client" asp-action="Index"><i class="bi bi-people"></i> Clients</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Payments")" asp-area="" asp-controller="Payments" asp-action="Index"><i class="bi bi-receipt"></i> Payments</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="container pt-4 pb-5">
        @RenderBody()
    </main>

    <footer class="footer py-4">
        <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
            <span class="footer-brand"><i class="bi bi-buildings-fill"></i> StayFinder</span>
            <span>Stays worth remembering &middot; &copy; 2026</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
