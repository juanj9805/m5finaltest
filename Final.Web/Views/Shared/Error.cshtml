@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="empty-state mx-auto anim-in" style="max-width: 560px; margin-top: 3rem;">
    <div class="empty-icon" style="background: var(--danger-soft); color: var(--danger);">
        <i class="bi bi-emoji-dizzy"></i>
    </div>
    <h3>Something went wrong</h3>
    <p>An error occurred while processing your request. Please try again — if it keeps happening, contact support.</p>
    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary"><i class="bi bi-house"></i> Back to home</a>
</div>
